# ============================================================================
#  Showroom Omnichannel Sales System — environment template
#  Copy to .env and fill in. NEVER commit .env.
# ============================================================================

# ---- Public URLs / domain ----------------------------------------------------
# The public HTTPS hostname Caddy serves (Meta webhooks require HTTPS).
PUBLIC_HOSTNAME=showroom.example.com
FRONTEND_URL=https://showroom.example.com
# Email used by Caddy for Let's Encrypt TLS certificates.
ACME_EMAIL=admin@example.com

# ---- Shared Postgres (pgvector image serves both Chatwoot and our services) --
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
# Chatwoot uses this database; the AI service uses its own (created on first boot).
POSTGRES_DB=chatwoot
AI_KB_DB=marketing_ai

# ---- Redis -------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# ============================================================================
#  Chatwoot
#  Most Meta channel credentials are entered in the Chatwoot UI, NOT here.
# ============================================================================
# Generate with: openssl rand -hex 64
SECRET_KEY_BASE=change-me-run-openssl-rand-hex-64
RAILS_ENV=production
NODE_ENV=production
# Default locale for the agent dashboard (Arabic). Agents can switch per-user.
DEFAULT_LOCALE=ar
# SMTP (optional, for agent invites / password resets)
MAILER_SENDER_EMAIL=showroom <noreply@example.com>
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# A Chatwoot "access token" for an agent-bot / admin used by our services to read
# conversations and post draft notes. Create it in Chatwoot → Profile → Access Token
# (or an Agent Bot token) AFTER first boot, then paste here and restart the services.
CHATWOOT_BASE_URL=http://chatwoot:3000
CHATWOOT_API_ACCESS_TOKEN=paste-after-first-boot
CHATWOOT_ACCOUNT_ID=1
# Shared secret Chatwoot signs webhooks/agent-bot calls with (we verify it).
CHATWOOT_WEBHOOK_SECRET=change-me-webhook-secret

# ============================================================================
#  AI / Knowledge base service
# ============================================================================
# Anthropic (Claude) — drafts replies. See the claude-api skill.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# Model used for drafting replies (Sonnet is fast + cost-effective at volume).
CLAUDE_DRAFT_MODEL=claude-sonnet-4-6
# Embeddings provider for the product knowledge base (multilingual: AR + EN).
# Default: Voyage AI (Anthropic-recommended). Set EMBEDDINGS_PROVIDER=openai to switch.
EMBEDDINGS_PROVIDER=voyage
VOYAGE_API_KEY=pa-xxxxxxxx
VOYAGE_MODEL=voyage-3
VOYAGE_DIMENSIONS=1024
# Only needed if EMBEDDINGS_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-large

AI_KB_PORT=4000
# Admin token protecting the product-catalog CRUD + ad-routing admin endpoints.
AI_KB_ADMIN_TOKEN=change-me-admin-token

# ============================================================================
#  Follow-up scheduler
# ============================================================================
# How long a conversation may sit idle (no customer message) before a follow-up.
FOLLOWUP_IDLE_HOURS=24
# Cron expression for the scheduler sweep (default: every 30 minutes).
FOLLOWUP_CRON=*/30 * * * *
# Only follow up conversations in these statuses (Chatwoot: open|pending|snoozed).
FOLLOWUP_STATUSES=open,pending
