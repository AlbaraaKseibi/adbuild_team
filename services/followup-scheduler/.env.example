# Local/dev env for followup-scheduler (in Docker these come from the root .env via compose).
CHATWOOT_BASE_URL=http://localhost:3000
CHATWOOT_API_ACCESS_TOKEN=paste-token
CHATWOOT_ACCOUNT_ID=1

FOLLOWUP_IDLE_HOURS=24
FOLLOWUP_CRON=*/30 * * * *
FOLLOWUP_STATUSES=open,pending
# Set true to run one sweep immediately at startup (handy for testing).
FOLLOWUP_RUN_ON_BOOT=false
