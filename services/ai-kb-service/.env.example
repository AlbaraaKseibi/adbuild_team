# Local/dev env for ai-kb-service (in Docker these come from the root .env via compose).
AI_KB_PORT=4000
DATABASE_URL=postgres://postgres:password@localhost:5432/marketing_ai

CHATWOOT_BASE_URL=http://localhost:3000
CHATWOOT_API_ACCESS_TOKEN=paste-token
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_WEBHOOK_SECRET=change-me-webhook-secret

ANTHROPIC_API_KEY=sk-ant-xxxx
CLAUDE_DRAFT_MODEL=claude-sonnet-4-6

EMBEDDINGS_PROVIDER=voyage
VOYAGE_API_KEY=pa-xxxx
VOYAGE_MODEL=voyage-3
VOYAGE_DIMENSIONS=1024
OPENAI_API_KEY=
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-large

AI_KB_ADMIN_TOKEN=change-me-admin-token
